{
  "name": "sandbox-form-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "e2e": "cypress run",
    "e2e:open": "cypress open",
    "e2e:ci": "start-server-and-test start http://localhost:4200 e2e",
    "build:coverage": "ng build --configuration development",
    "instrument:coverage": "rm -rf .nyc_output coverage dist-coverage && nyc instrument dist/sandbox-form-angular/browser dist-coverage && cp dist-coverage/main.js dist/sandbox-form-angular/browser/main.js",
    "start:coverage": "npm run build:coverage && npm run instrument:coverage && http-server dist/sandbox-form-angular/browser -p 4300 -s",
    "coverage:report": "nyc report --reporter=text-summary --reporter=html",
    "e2e:coverage": "start-server-and-test start:coverage http://localhost:4300 \"CYPRESS_baseUrl=http://localhost:4300 cypress run\" && npm run coverage:report"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@cypress/code-coverage": "^4.0.2",
    "cypress": "^15.12.0",
    "http-server": "^14.1.1",
    "jsdom": "^28.0.0",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.1.5",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
